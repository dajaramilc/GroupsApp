# ── Application ──────────────────────────────────────────
APP_NAME=GroupsApp
DEBUG=false

# ── Database ─────────────────────────────────────────────
# Local Docker DB:
# DATABASE_URL=postgresql+asyncpg://groupsapp:groupsapp@db:5432/groupsapp
#
# Supabase Managed DB (Recommended for MVP):
# Note: Ensure you change `postgresql://` to `postgresql+asyncpg://`
DATABASE_URL=postgresql+asyncpg://postgres.xxxxx:PASSWORD@aws-1-us-east-2.pooler.supabase.com:5432/postgres

# ── JWT ──────────────────────────────────────────────────
# IMPORTANTE: Generar un secreto seguro en producción:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── File storage ─────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# ── S3 Storage (solo para producción en AWS) ─────────────
# Cambiar a "s3" cuando se despliegue en AWS
STORAGE_BACKEND=local
S3_BUCKET_UPLOADS=groupsapp-uploads-tu-identificador
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── CORS (solo para producción) ──────────────────────────
# En local: "*" permite todo. En producción: poner la URL de CloudFront.
# Ejemplo: https://d1234abcdef.cloudfront.net
CORS_ORIGINS=*

# ── Presence ─────────────────────────────────────────────
PRESENCE_TIMEOUT_SECONDS=120
